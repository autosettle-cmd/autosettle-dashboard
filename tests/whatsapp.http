### -------------------------------------------------------
### Test 14: Text correction (AWAITING_CORRECTION flow)
### PREREQUISITE: Send blurry receipt → tap No → session is AWAITING_CORRECTION
### Then type the correction (e.g. "merchant is Petronas, amount is 45.50")
### Expected: Claim saved with corrected values, session deleted, confirmation sent
### -------------------------------------------------------
POST {{baseUrl}}/api/whatsapp/webhook
Content-Type: application/json

{
  "entry": [
    {
      "changes": [
        {
          "value": {
            "messages": [
              {
                "from": "{{jeffPhone}}",
                "type": "text",
                "text": {
                  "body": "merchant is Petronas, amount is 45.50"
                }
              }
            ]
          }
        }
      ]
    }
  ]
}

