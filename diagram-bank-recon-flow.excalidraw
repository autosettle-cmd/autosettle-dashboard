    {
      "type": "text",
      "id": "text_unmatch",
      "x": 15,
      "y": 738,
      "width": 470,
      "height": 100,
      "text": "UNMATCH / DELETE STATEMENT:\n1. Reverse bank_recon JVs\n2. Delete BankTransactionInvoice → recalc invoice amount_paid\n3. Delete BankTransactionClaim → claim payment_status → unpaid\n4. Clear matched_sales_invoice_id → update sales invoice\n5. Delete legacy auto-created Payments + PaymentReceipts\n6. recon_status → unmatched (or delete if statement deleted)",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
