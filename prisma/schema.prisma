generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  accountant
  admin
  employee
}

enum UserStatus {
  active
  pending_onboarding
  rejected
  inactive
}

enum Plan {
  free
  paid
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}

enum ClaimStatus {
  pending_review
  reviewed
}

enum ApprovalStatus {
  pending_approval
  approved
  not_approved
}

enum PaymentStatus {
  unpaid
  paid
}

enum SubmittedVia {
  whatsapp
  dashboard
}

enum ClaimType {
  claim
  receipt
}

enum SessionState {
  IDLE
  COLLECTING
}

enum InvoiceStatus {
  pending_review
  reviewed
}

enum InvoicePaymentStatus {
  unpaid
  partially_paid
  paid
}

enum SupplierLinkStatus {
  auto_matched
  unmatched
  confirmed
}

model Firm {
  id                  String    @id @default(uuid())
  name                String
  registration_number String?
  contact_email       String?
  contact_phone       String?
  is_active           Boolean   @default(true)
  receipt_count       Int       @default(0)
  plan                Plan      @default(free)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  users           User[]
  employees       Employee[]
  claims          Claim[]

  invoices        Invoice[]
  suppliers       Supplier[]
  payments        Payment[]
  categories             Category[]
  categoryFirmOverrides  CategoryFirmOverride[]
  accountantFirms        AccountantFirm[]
}

model Employee {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  email      String?
  firm_id    String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  firm         Firm         @relation(fields: [firm_id], references: [id])
  users        User[]
  claims       Claim[]
  invoices     Invoice[]
  messageLogs  MessageLog[]
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password_hash String
  name          String
  role          UserRole
  status        UserStatus @default(active)
  firm_id       String?
  employee_id   String?
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  firm           Firm?            @relation(fields: [firm_id], references: [id])
  employee       Employee?        @relation(fields: [employee_id], references: [id])
  accountantFirms AccountantFirm[]
}

model AccountantFirm {
  id         String   @id @default(uuid())
  user_id    String
  firm_id    String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
  firm Firm @relation(fields: [firm_id], references: [id])

  @@unique([user_id, firm_id])
}

model Category {
  id         String   @id @default(uuid())
  firm_id    String?
  name       String
  tax_code   String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  firm      Firm?                @relation(fields: [firm_id], references: [id])
  claims    Claim[]
  invoices  Invoice[]
  overrides CategoryFirmOverride[]

  @@unique([firm_id, name])
}

model CategoryFirmOverride {
  id          String   @id @default(uuid())
  category_id String
  firm_id     String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  category Category @relation(fields: [category_id], references: [id])
  firm     Firm     @relation(fields: [firm_id], references: [id])

  @@unique([category_id, firm_id])
}

model Claim {
  id               String         @id @default(uuid())
  firm_id          String
  employee_id      String
  claim_date       DateTime       @db.Date
  merchant         String
  description      String?
  receipt_number   String?
  amount           Decimal        @db.Decimal(10, 2)
  category_id      String
  confidence       Confidence
  status           ClaimStatus    @default(pending_review)
  approval         ApprovalStatus @default(pending_approval)
  payment_status   PaymentStatus  @default(unpaid)
  rejection_reason String?
  file_url         String?
  file_download_url String?
  thumbnail_url    String?
  submitted_via    SubmittedVia
  type             ClaimType      @default(claim)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  firm     Firm     @relation(fields: [firm_id], references: [id])
  employee Employee @relation(fields: [employee_id], references: [id])
  category Category @relation(fields: [category_id], references: [id])
  paymentReceipts PaymentReceipt[]
}


model Supplier {
  id            String   @id @default(uuid())
  firm_id       String
  name          String
  contact_email String?
  contact_phone String?
  notes         String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  firm     Firm            @relation(fields: [firm_id], references: [id])
  aliases  SupplierAlias[]
  invoices Invoice[]
  payments Payment[]

  @@unique([firm_id, name])
}

model SupplierAlias {
  id           String   @id @default(uuid())
  supplier_id  String
  alias        String
  is_confirmed Boolean  @default(false)
  created_at   DateTime @default(now())

  supplier Supplier @relation(fields: [supplier_id], references: [id])

  @@unique([supplier_id, alias])
}

model Invoice {
  id                  String               @id @default(uuid())
  firm_id             String
  uploaded_by         String
  supplier_id         String?
  supplier_link_status SupplierLinkStatus  @default(unmatched)
  vendor_name_raw     String
  invoice_number      String?
  issue_date          DateTime             @db.Date
  due_date            DateTime?            @db.Date
  payment_terms       String?
  subtotal            Decimal?             @db.Decimal(10, 2)
  tax_amount          Decimal?             @db.Decimal(10, 2)
  total_amount        Decimal              @db.Decimal(10, 2)
  category_id         String
  confidence          Confidence
  status              InvoiceStatus        @default(pending_review)
  payment_status      InvoicePaymentStatus @default(unpaid)
  amount_paid         Decimal              @default(0) @db.Decimal(10, 2)
  file_url            String?
  file_download_url   String?
  thumbnail_url       String?
  submitted_via       SubmittedVia
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  firm     Firm      @relation(fields: [firm_id], references: [id])
  uploader Employee  @relation(fields: [uploaded_by], references: [id])
  supplier            Supplier?            @relation(fields: [supplier_id], references: [id])
  category            Category             @relation(fields: [category_id], references: [id])
  paymentAllocations  PaymentAllocation[]
}

model Payment {
  id           String   @id @default(uuid())
  firm_id      String
  supplier_id  String
  amount       Decimal  @db.Decimal(10, 2)
  payment_date DateTime @db.Date
  reference    String?
  notes        String?
  created_at   DateTime @default(now())

  firm        Firm                @relation(fields: [firm_id], references: [id])
  supplier    Supplier            @relation(fields: [supplier_id], references: [id])
  allocations PaymentAllocation[]
  receipts    PaymentReceipt[]
}

model PaymentAllocation {
  id         String  @id @default(uuid())
  payment_id String
  invoice_id String
  amount     Decimal @db.Decimal(10, 2)

  payment Payment @relation(fields: [payment_id], references: [id])
  invoice Invoice @relation(fields: [invoice_id], references: [id])

  @@unique([payment_id, invoice_id])
}

model PaymentReceipt {
  id         String @id @default(uuid())
  payment_id String
  claim_id   String

  payment Payment @relation(fields: [payment_id], references: [id])
  claim   Claim   @relation(fields: [claim_id], references: [id])

  @@unique([payment_id, claim_id])
}

model Session {
  id              String       @id @default(uuid())
  phone           String       @unique
  state           SessionState @default(IDLE)
  step            String?
  intent          String?
  pending_receipt Json?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
}

model MessageLog {
  id             String    @id @default(uuid())
  phone          String
  employee_id    String?
  message_type   String
  ocr_confidence String?
  processing_ms  Int?
  error          String?
  received_at    DateTime  @default(now())

  employee Employee? @relation(fields: [employee_id], references: [id])
}
