generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  accountant
  admin
  employee
  platform_owner
}

enum UserStatus {
  active
  pending_onboarding
  rejected
  inactive
}

enum Plan {
  free
  paid
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}

enum ClaimStatus {
  pending_review
  reviewed
}

enum ApprovalStatus {
  pending_approval
  approved
  not_approved
}

enum PaymentStatus {
  unpaid
  partially_paid
  paid
}

enum SubmittedVia {
  whatsapp
  dashboard
}

enum ClaimType {
  claim
  receipt
  mileage
}

enum SessionState {
  IDLE
  COLLECTING
}

enum InvoiceStatus {
  pending_review
  reviewed
}

enum InvoicePaymentStatus {
  unpaid
  partially_paid
  paid
}

enum SupplierLinkStatus {
  auto_matched
  unmatched
  confirmed
}

enum LhdnStatus {
  draft
  pending
  valid
  invalid
  cancelled
}

enum PaymentDirection {
  outgoing
  incoming
}

model Firm {
  id                  String    @id @default(uuid())
  name                String
  registration_number String?
  contact_email       String?
  contact_phone       String?
  is_active           Boolean   @default(true)
  receipt_count       Int       @default(0)
  plan                Plan      @default(free)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  // LHDN fields
  tin                    String?
  brn                    String?
  msic_code              String?
  sst_registration_number String?
  address_line1          String?
  address_line2          String?
  city                   String?
  postal_code            String?
  state                  String?
  country                String?   @default("MYS")
  lhdn_client_id         String?
  lhdn_client_secret     String?

  // GL defaults
  default_trade_payables_gl_id    String?
  default_staff_claims_gl_id      String?
  default_trade_receivables_gl_id String?
  default_retained_earnings_gl_id String?

  // Google Drive folder IDs (auto-created on first upload)
  drive_root_folder_id            String?
  drive_claims_folder_id          String?
  drive_invoices_folder_id        String?
  drive_bank_statements_folder_id String?

  users           User[]
  employees       Employee[]
  claims          Claim[]

  invoices        Invoice[]
  salesInvoices   SalesInvoice[]
  suppliers       Supplier[]
  payments        Payment[]
  categories             Category[]
  categoryFirmOverrides  CategoryFirmOverride[]
  accountantFirms        AccountantFirm[]
  bankStatements         BankStatement[]
  glAccounts             GLAccount[]
  fiscalYears            FiscalYear[]
  taxCodes               TaxCode[]
  bankAccounts           BankAccount[]
  journalEntries         JournalEntry[]
  mileage_rate_per_km    Decimal?  @db.Decimal(4, 2)

  defaultTradePayables    GLAccount? @relation("FirmTradePayables", fields: [default_trade_payables_gl_id], references: [id], onDelete: SetNull)
  defaultStaffClaims      GLAccount? @relation("FirmStaffClaims", fields: [default_staff_claims_gl_id], references: [id], onDelete: SetNull)
  defaultTradeReceivables GLAccount? @relation("FirmTradeReceivables", fields: [default_trade_receivables_gl_id], references: [id], onDelete: SetNull)
  defaultRetainedEarnings GLAccount? @relation("FirmRetainedEarnings", fields: [default_retained_earnings_gl_id], references: [id], onDelete: SetNull)
}

model Employee {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  email      String?
  firm_id    String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  firm          Firm           @relation(fields: [firm_id], references: [id])
  users         User[]
  claims        Claim[]
  invoices      Invoice[]
  salesInvoices SalesInvoice[]
  messageLogs   MessageLog[]
  payments      Payment[]

  @@index([firm_id])
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password_hash String
  name          String
  role          UserRole
  status        UserStatus @default(active)
  firm_id       String?
  employee_id   String?
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  firm           Firm?            @relation(fields: [firm_id], references: [id])
  employee       Employee?        @relation(fields: [employee_id], references: [id])
  accountantFirms AccountantFirm[]
  bankStatements  BankStatement[]

  @@index([firm_id])
}

model AccountantFirm {
  id         String   @id @default(uuid())
  user_id    String
  firm_id    String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  firm Firm @relation(fields: [firm_id], references: [id], onDelete: Cascade)

  @@unique([user_id, firm_id])
}

model Category {
  id         String   @id @default(uuid())
  firm_id    String?
  name       String
  tax_code   String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  firm           Firm?                @relation(fields: [firm_id], references: [id])
  claims         Claim[]
  invoices       Invoice[]
  salesInvoices  SalesInvoice[]
  overrides      CategoryFirmOverride[]

  @@unique([firm_id, name])
  @@index([firm_id])
}

model CategoryFirmOverride {
  id            String   @id @default(uuid())
  category_id   String
  firm_id       String
  is_active     Boolean  @default(true)
  gl_account_id String?
  created_at    DateTime @default(now())

  category  Category   @relation(fields: [category_id], references: [id], onDelete: Cascade)
  firm      Firm       @relation(fields: [firm_id], references: [id])
  glAccount GLAccount? @relation(fields: [gl_account_id], references: [id])

  @@unique([category_id, firm_id])
}

model Claim {
  id               String         @id @default(uuid())
  firm_id          String
  employee_id      String
  claim_date       DateTime       @db.Date
  merchant         String
  description      String?
  receipt_number   String?
  amount           Decimal        @db.Decimal(10, 2)
  category_id      String
  confidence       Confidence
  status           ClaimStatus    @default(pending_review)
  approval         ApprovalStatus @default(pending_approval)
  payment_status   PaymentStatus  @default(unpaid)
  amount_paid      Decimal        @default(0) @db.Decimal(10, 2)
  rejection_reason String?
  file_url         String?
  file_download_url String?
  thumbnail_url    String?
  file_hash        String?
  submitted_via    SubmittedVia
  type             ClaimType      @default(claim)
  from_location    String?
  to_location      String?
  distance_km      Decimal?       @db.Decimal(8, 2)
  trip_purpose     String?
  gl_account_id          String?
  contra_gl_account_id   String?
  tax_amount       Decimal?       @db.Decimal(10, 2)
  tax_rate         Decimal?       @db.Decimal(5, 2)
  tax_code_id      String?
  matched_bank_txn_id    String?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  firm     Firm     @relation(fields: [firm_id], references: [id])
  employee Employee @relation(fields: [employee_id], references: [id])
  category Category @relation(fields: [category_id], references: [id])
  glAccount      GLAccount? @relation("ClaimExpenseGL", fields: [gl_account_id], references: [id])
  contraGlAccount GLAccount? @relation("ClaimContraGL", fields: [contra_gl_account_id], references: [id])
  taxCode    TaxCode?   @relation(fields: [tax_code_id], references: [id], onDelete: SetNull)
  matchedBankTxn BankTransaction? @relation(fields: [matched_bank_txn_id], references: [id], onDelete: SetNull)
  bankTxnAllocations BankTransactionClaim[]
  paymentReceipts PaymentReceipt[]
  invoiceReceiptLinks InvoiceReceiptLink[]

  @@index([firm_id, type, claim_date])
  @@index([firm_id, type, status])
  @@index([firm_id, claim_date])
  @@index([firm_id, approval])
  @@index([firm_id, payment_status])
  @@index([firm_id, file_hash])
  @@index([employee_id, claim_date])
  @@index([matched_bank_txn_id])
}


model Supplier {
  id            String   @id @default(uuid())
  firm_id       String
  name          String
  contact_email String?
  contact_phone String?
  notes         String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // LHDN buyer fields
  tin                    String?
  brn                    String?
  sst_registration_number String?
  address_line1          String?
  address_line2          String?
  city                   String?
  postal_code            String?
  state                  String?
  country                String?   @default("MYS")

  // Default GL for invoice approval (learned from first approval, auto-applied thereafter)
  default_gl_account_id       String?
  // Supplier's own Trade Creditor sub-account (auto-created under 400-000)
  default_contra_gl_account_id String?

  firm          Firm            @relation(fields: [firm_id], references: [id])
  defaultGlAccount      GLAccount?  @relation("SupplierDefaultGL", fields: [default_gl_account_id], references: [id])
  defaultContraGlAccount GLAccount? @relation("SupplierContraGL", fields: [default_contra_gl_account_id], references: [id])
  aliases       SupplierAlias[]
  invoices      Invoice[]
  salesInvoices SalesInvoice[]
  payments      Payment[]

  @@unique([firm_id, name])
  @@index([firm_id])
}

model SupplierAlias {
  id           String   @id @default(uuid())
  supplier_id  String
  alias        String
  is_confirmed Boolean  @default(false)
  created_at   DateTime @default(now())

  supplier Supplier @relation(fields: [supplier_id], references: [id], onDelete: Cascade)

  @@unique([supplier_id, alias])
  @@index([supplier_id])
}

model Invoice {
  id                  String               @id @default(uuid())
  firm_id             String
  uploaded_by         String
  supplier_id         String?
  supplier_link_status SupplierLinkStatus  @default(unmatched)
  vendor_name_raw     String
  invoice_number      String?
  issue_date          DateTime             @db.Date
  due_date            DateTime?            @db.Date
  payment_terms       String?
  subtotal            Decimal?             @db.Decimal(10, 2)
  tax_amount          Decimal?             @db.Decimal(10, 2)
  total_amount        Decimal              @db.Decimal(10, 2)
  category_id         String
  confidence          Confidence
  status              InvoiceStatus        @default(pending_review)
  payment_status      InvoicePaymentStatus @default(unpaid)
  amount_paid         Decimal              @default(0) @db.Decimal(10, 2)
  file_url            String?
  file_download_url   String?
  thumbnail_url       String?
  file_hash           String?
  submitted_via       SubmittedVia
  gl_account_id            String?
  contra_gl_account_id     String?
  approval            ApprovalStatus       @default(pending_approval)
  rejection_reason    String?
  notes               String?
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  firm     Firm      @relation(fields: [firm_id], references: [id])
  uploader Employee  @relation(fields: [uploaded_by], references: [id])
  supplier            Supplier?            @relation(fields: [supplier_id], references: [id])
  category            Category             @relation(fields: [category_id], references: [id])
  glAccount           GLAccount?           @relation("InvoiceExpenseGL", fields: [gl_account_id], references: [id])
  contraGlAccount     GLAccount?           @relation("InvoiceContraGL", fields: [contra_gl_account_id], references: [id])
  paymentAllocations  PaymentAllocation[]
  bankTxnAllocations  BankTransactionInvoice[]
  receiptLinks        InvoiceReceiptLink[]

  @@index([firm_id, status])
  @@index([firm_id, issue_date])
  @@index([firm_id, file_hash])
  @@index([supplier_id])
  @@index([firm_id, payment_status])
  @@index([firm_id, approval])
  @@index([uploaded_by])
}

model Payment {
  id           String   @id @default(uuid())
  firm_id      String
  supplier_id  String?
  employee_id  String?
  amount       Decimal  @db.Decimal(10, 2)
  payment_date DateTime @db.Date
  reference    String?
  notes        String?
  created_at   DateTime @default(now())

  direction   PaymentDirection    @default(outgoing)

  firm             Firm                     @relation(fields: [firm_id], references: [id])
  supplier         Supplier?                @relation(fields: [supplier_id], references: [id])
  employee         Employee?                @relation(fields: [employee_id], references: [id])
  allocations      PaymentAllocation[]
  salesAllocations SalesPaymentAllocation[]
  receipts         PaymentReceipt[]
  bankTransactions BankTransaction[]

  @@index([supplier_id, direction, payment_date])
  @@index([employee_id, payment_date])
  @@index([firm_id, payment_date])
}

model PaymentAllocation {
  id         String  @id @default(uuid())
  payment_id String
  invoice_id String
  amount     Decimal @db.Decimal(10, 2)

  payment Payment @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@unique([payment_id, invoice_id])
  @@index([invoice_id])
}

model PaymentReceipt {
  id         String  @id @default(uuid())
  payment_id String
  claim_id   String
  amount     Decimal @default(0) @db.Decimal(10, 2)

  payment Payment @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  claim   Claim   @relation(fields: [claim_id], references: [id], onDelete: Cascade)

  @@unique([payment_id, claim_id])
  @@index([claim_id])
}

model InvoiceReceiptLink {
  id          String   @id @default(uuid())
  invoice_id  String
  claim_id    String
  amount      Decimal  @db.Decimal(10, 2)
  linked_at   DateTime @default(now())
  linked_by   String?

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  claim   Claim   @relation(fields: [claim_id], references: [id], onDelete: Cascade)

  @@unique([invoice_id, claim_id])
  @@index([claim_id])
  @@index([invoice_id])
}

model Session {
  id              String       @id @default(uuid())
  phone           String       @unique
  state           SessionState @default(IDLE)
  step            String?
  intent          String?
  pending_receipt Json?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
}

model MessageLog {
  id             String    @id @default(uuid())
  phone          String
  employee_id    String?
  message_id     String?   @unique
  message_type   String
  ocr_confidence String?
  processing_ms  Int?
  error          String?
  received_at    DateTime  @default(now())

  employee Employee? @relation(fields: [employee_id], references: [id])

  @@index([employee_id])
  @@index([phone, employee_id])
}

// ─── Sales Invoicing (Issued) ────────────────────────────────────────────────

model SalesInvoice {
  id                   String               @id @default(uuid())
  firm_id              String
  supplier_id          String
  created_by           String?
  invoice_number       String
  issue_date           DateTime             @db.Date
  due_date             DateTime?            @db.Date
  currency             String               @default("MYR")
  subtotal             Decimal              @db.Decimal(10, 2)
  tax_amount           Decimal              @default(0) @db.Decimal(10, 2)
  total_amount         Decimal              @db.Decimal(10, 2)
  payment_status       InvoicePaymentStatus @default(unpaid)
  amount_paid          Decimal              @default(0) @db.Decimal(10, 2)
  notes                String?
  category_id          String?
  gl_account_id        String?
  approval             ApprovalStatus       @default(pending_approval)

  // LHDN MyInvois fields
  lhdn_submission_uid  String?
  lhdn_document_uuid   String?
  lhdn_long_id         String?
  lhdn_status          LhdnStatus           @default(draft)
  lhdn_qr_url          String?
  lhdn_submitted_at    DateTime?
  lhdn_validated_at    DateTime?
  lhdn_error           String?

  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt

  firm                 Firm                 @relation(fields: [firm_id], references: [id])
  buyer                Supplier             @relation(fields: [supplier_id], references: [id])
  creator              Employee?            @relation(fields: [created_by], references: [id])
  category             Category?            @relation(fields: [category_id], references: [id])
  glAccount            GLAccount?           @relation(fields: [gl_account_id], references: [id])
  items                SalesInvoiceItem[]
  paymentAllocations   SalesPaymentAllocation[]
  bankTransactions     BankTransaction[]

  @@index([firm_id, issue_date])
  @@index([firm_id, lhdn_status])
  @@index([firm_id, approval])
  @@index([created_by])
  @@unique([firm_id, invoice_number])
}

model SalesInvoiceItem {
  id                String   @id @default(uuid())
  sales_invoice_id  String
  description       String
  quantity          Decimal  @db.Decimal(10, 3)
  unit_price        Decimal  @db.Decimal(10, 2)
  discount          Decimal  @default(0) @db.Decimal(10, 2)
  tax_type          String?
  tax_rate          Decimal  @default(0) @db.Decimal(5, 2)
  tax_amount        Decimal  @default(0) @db.Decimal(10, 2)
  line_total        Decimal  @db.Decimal(10, 2)
  sort_order        Int      @default(0)

  salesInvoice      SalesInvoice @relation(fields: [sales_invoice_id], references: [id], onDelete: Cascade)
}

model SalesPaymentAllocation {
  id                String  @id @default(uuid())
  payment_id        String
  sales_invoice_id  String
  amount            Decimal @db.Decimal(10, 2)

  payment           Payment       @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  salesInvoice      SalesInvoice  @relation(fields: [sales_invoice_id], references: [id], onDelete: Cascade)

  @@unique([payment_id, sales_invoice_id])
  @@index([sales_invoice_id])
}

// ─── Bank Reconciliation ─────────────────────────────────────────────────────

// ─── Accounting Foundation ───────────────────────────────────────────────────

enum AccountType {
  Asset
  Liability
  Equity
  Revenue
  Expense
}

enum NormalBalance {
  Debit
  Credit
}

enum FiscalYearStatus {
  open
  closed
}

enum PeriodStatus {
  open
  closed
  locked
}

enum AuditAction {
  create
  update
  delete
}

enum ReconStatus {
  unmatched
  matched
  manually_matched
  excluded
}

enum JournalEntryStatus {
  posted
  reversed
}

enum JournalSourceType {
  claim_approval
  invoice_posting
  sales_invoice_posting
  bank_recon
  manual
  year_end_close
}

model BankStatement {
  id              String    @id @default(uuid())
  firm_id         String
  bank_name       String
  account_number  String?
  statement_date  DateTime  @db.Date
  opening_balance Decimal?  @db.Decimal(12, 2)
  closing_balance Decimal?  @db.Decimal(12, 2)
  file_name       String
  file_hash       String    @unique
  file_url        String?
  uploaded_by     String
  period_start    DateTime? @db.Date
  period_end      DateTime? @db.Date
  created_at      DateTime  @default(now())

  firm         Firm              @relation(fields: [firm_id], references: [id])
  uploader     User              @relation(fields: [uploaded_by], references: [id])
  transactions BankTransaction[]

  @@index([firm_id, statement_date])
  @@index([firm_id, account_number])
}

model BankTransaction {
  id                 String      @id @default(uuid())
  bank_statement_id  String
  transaction_date   DateTime    @db.Date
  description        String
  reference          String?
  cheque_number      String?
  debit              Decimal?    @db.Decimal(12, 2)
  credit             Decimal?    @db.Decimal(12, 2)
  balance            Decimal?    @db.Decimal(12, 2)
  recon_status       ReconStatus @default(unmatched)
  matched_payment_id       String?
  matched_sales_invoice_id String?
  matched_at               DateTime?
  matched_by               String?
  notes                    String?
  created_at         DateTime    @default(now())

  bankStatement      BankStatement @relation(fields: [bank_statement_id], references: [id], onDelete: Cascade)
  matchedPayment     Payment?      @relation(fields: [matched_payment_id], references: [id])
  matchedSalesInvoice SalesInvoice? @relation(fields: [matched_sales_invoice_id], references: [id])
  matchedClaims      Claim[]
  invoiceAllocations BankTransactionInvoice[]
  claimAllocations   BankTransactionClaim[]

  @@index([bank_statement_id, recon_status])
  @@index([bank_statement_id, transaction_date])
  @@index([matched_sales_invoice_id])
  @@index([matched_payment_id])
}

model BankTransactionInvoice {
  id                  String   @id @default(uuid())
  bank_transaction_id String
  invoice_id          String
  amount              Decimal  @db.Decimal(12, 2)

  bankTransaction BankTransaction @relation(fields: [bank_transaction_id], references: [id], onDelete: Cascade)
  invoice         Invoice         @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@unique([bank_transaction_id, invoice_id])
  @@index([invoice_id])
}

model BankTransactionClaim {
  id                  String   @id @default(uuid())
  bank_transaction_id String
  claim_id            String
  amount              Decimal  @db.Decimal(12, 2)

  bankTransaction BankTransaction @relation(fields: [bank_transaction_id], references: [id], onDelete: Cascade)
  claim           Claim           @relation(fields: [claim_id], references: [id], onDelete: Cascade)

  @@unique([bank_transaction_id, claim_id])
  @@index([claim_id])
}

// ─── Chart of Accounts ──────────────────────────────────────────────────────

model GLAccount {
  id             String        @id @default(uuid())
  firm_id        String
  account_code   String
  name           String
  account_type   AccountType
  normal_balance NormalBalance
  parent_id      String?
  is_active      Boolean       @default(true)
  is_system      Boolean       @default(false)
  sort_order     Int           @default(0)
  description    String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  firm     Firm       @relation(fields: [firm_id], references: [id])
  parent   GLAccount? @relation("GLAccountHierarchy", fields: [parent_id], references: [id])
  children GLAccount[] @relation("GLAccountHierarchy")

  claims                Claim[]  @relation("ClaimExpenseGL")
  claimsContra          Claim[]  @relation("ClaimContraGL")
  invoices              Invoice[] @relation("InvoiceExpenseGL")
  invoicesContra        Invoice[] @relation("InvoiceContraGL")
  salesInvoices         SalesInvoice[]
  categoryFirmOverrides CategoryFirmOverride[]
  taxCodes              TaxCode[]
  journalLines          JournalLine[]
  bankAccounts          BankAccount[]
  firmsTradePayables    Firm[]  @relation("FirmTradePayables")
  firmsStaffClaims      Firm[]  @relation("FirmStaffClaims")
  firmsTradeReceivables Firm[]  @relation("FirmTradeReceivables")
  firmsRetainedEarnings Firm[]  @relation("FirmRetainedEarnings")
  suppliersDefaultGL    Supplier[] @relation("SupplierDefaultGL")
  suppliersContraGL     Supplier[] @relation("SupplierContraGL")

  @@unique([firm_id, account_code])
  @@index([firm_id, account_type])
  @@index([firm_id, is_active])
  @@index([parent_id])
}

// ─── Fiscal Periods ─────────────────────────────────────────────────────────

model FiscalYear {
  id         String           @id @default(uuid())
  firm_id    String
  year_label String
  start_date DateTime         @db.Date
  end_date   DateTime         @db.Date
  status     FiscalYearStatus @default(open)
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  firm    Firm     @relation(fields: [firm_id], references: [id])
  periods Period[]

  @@unique([firm_id, year_label])
  @@index([firm_id, status])
}

model Period {
  id             String       @id @default(uuid())
  fiscal_year_id String
  period_number  Int
  start_date     DateTime     @db.Date
  end_date       DateTime     @db.Date
  status         PeriodStatus @default(open)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  fiscalYear     FiscalYear     @relation(fields: [fiscal_year_id], references: [id])
  journalEntries JournalEntry[]

  @@unique([fiscal_year_id, period_number])
  @@index([fiscal_year_id, status])
}

// ─── Audit Trail ────────────────────────────────────────────────────────────

model AuditLog {
  id             String      @id @default(uuid())
  firm_id        String
  table_name     String
  record_id      String
  action         AuditAction
  changed_fields Json?
  old_values     Json?
  new_values     Json?
  user_id        String?
  user_name      String?
  timestamp      DateTime    @default(now())

  @@index([firm_id, table_name, timestamp])
  @@index([firm_id, record_id])
}

// ─── Tax Codes ──────────────────────────────────────────────────────────────

model TaxCode {
  id            String   @id @default(uuid())
  firm_id       String
  code          String
  description   String
  rate          Decimal  @db.Decimal(5, 2)
  tax_type      String
  gl_account_id String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  firm      Firm       @relation(fields: [firm_id], references: [id])
  glAccount GLAccount? @relation(fields: [gl_account_id], references: [id])
  claims    Claim[]

  @@unique([firm_id, code])
  @@index([firm_id, is_active])
}

// ─── Bank Accounts (GL mapping) ────────────────────────────────────────────

model BankAccount {
  id              String   @id @default(uuid())
  firm_id         String
  bank_name       String
  account_number  String
  gl_account_id   String
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  firm      Firm      @relation(fields: [firm_id], references: [id])
  glAccount GLAccount @relation(fields: [gl_account_id], references: [id])

  @@unique([firm_id, bank_name, account_number])
  @@index([firm_id])
}

// ─── Journal Entries (Double-Entry Ledger) ──────────────────────────────────

model JournalEntry {
  id              String             @id @default(uuid())
  firm_id         String
  voucher_number  String
  posting_date    DateTime           @db.Date
  period_id       String?
  description     String?
  source_type     JournalSourceType
  source_id       String?
  status          JournalEntryStatus @default(posted)
  reversed_by_id  String?            @unique
  reversal_of_id  String?            @unique
  created_by      String?
  created_at      DateTime           @default(now())

  firm           Firm           @relation(fields: [firm_id], references: [id])
  period         Period?        @relation(fields: [period_id], references: [id])
  reversedBy     JournalEntry?  @relation("JournalReversedBy", fields: [reversed_by_id], references: [id])
  reversedByOf   JournalEntry?  @relation("JournalReversedBy")
  reversalOf     JournalEntry?  @relation("JournalReversalOf", fields: [reversal_of_id], references: [id])
  originalEntry  JournalEntry?  @relation("JournalReversalOf")
  lines          JournalLine[]

  @@unique([firm_id, voucher_number])
  @@index([firm_id, posting_date])
  @@index([firm_id, source_type, source_id])
  @@index([period_id])
}

model JournalLine {
  id               String  @id @default(uuid())
  journal_entry_id String
  gl_account_id    String
  debit_amount     Decimal @default(0) @db.Decimal(12, 2)
  credit_amount    Decimal @default(0) @db.Decimal(12, 2)
  description      String?

  journalEntry JournalEntry @relation(fields: [journal_entry_id], references: [id], onDelete: Cascade)
  glAccount    GLAccount    @relation(fields: [gl_account_id], references: [id])

  @@index([journal_entry_id])
  @@index([gl_account_id])
}
